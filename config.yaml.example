server:
  port: 8080
  mode: "release"

database:
  path: "llmgate.db"

jwt:
  secret: "your-jwt-secret-key-change-this-in-production"
  expire_hours: 24

models:
  # GLM4.7 - 单实例部署示例
  - id: "glm4.7"
    name: "GLM 4.7"
    description: "智谱 GLM4.7 模型"
    enabled: true
    backends:
      - id: "glm4.7-prod-01"
        name: "北京节点-01"
        base_url: "http://glm4-7.internal:8000"
        api_key: "your-glm-api-key-here"
        model_name: "glm4"
        weight: 10
        region: "beijing"

  # Kimi2.5 - 多实例部署示例
  - id: "kimi2.5"
    name: "Kimi 2.5"
    description: "Moonshot Kimi 2.5"
    enabled: true
    backends:
      - id: "kimi2.5-gz-01"
        name: "广州节点-01"
        base_url: "https://api.kimi.com/coding/"
        api_key: "your-kimi-api-key-here"
        model_name: "Sonnet"
        weight: 20
        region: "guangzhou"

  # Qwen 模型示例
  - id: "qwen3.5-397b"
    name: "Qwen 3.5 397B"
    description: "通义千问 3.5 397B"
    enabled: true
    backends:
      - id: "qwen3.5-397b-prod"
        base_url: "http://qwen35-397b.internal:8000"
        model_name: "qwen3.5-397b-instruct"
        weight: 10

quota_policies:
  - name: "default"
    rate_limit: 60
    rate_limit_window: 60
    token_quota_daily: 100000
    models:
      - "glm4.7"
      - "kimi2.5"
      - "qwen3.5-397b"
  - name: "vip"
    rate_limit: 300
    rate_limit_window: 60
    token_quota_daily: 1000000
    models:
      - "*"

admin:
  default_email: "admin@llmgate.local"
  default_password: "change-this-password"

logs:
  path: "logs"
  retention_days: 7

# 并发控制配置
concurrency:
  global_limit: 100  # 全局最大并发请求数
  user_limit: 10     # 每个用户最大并发请求数

# 前端配置
frontend:
  feedback_url: "https://feedback.example.com"      # 用户反馈链接
  dev_manual_url: "https://docs.example.com"        # 开发手册链接
